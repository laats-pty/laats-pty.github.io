---
interface Props {
  logo: string;
}
const { logo } = Astro.props;
---

<header
  x-data="{ scrolled: false }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 20 })"
  x-bind:class="scrolled ? 'shadow-md' : 'shadow-none'"
  class="fixed top-0 left-0 right-0 z-50 h-16 bg-[var(--color-primary)] transition-shadow duration-200"
>
  <div class="max-w-6xl mx-auto px-4 md:px-8 h-full flex items-center justify-between">
    <a href="#inicio" class="flex items-center gap-2">
      <div class="bg-white rounded-md px-2 py-1 flex items-center">
        <img src={logo} alt="LAATS Safety and Quality Services" class="h-8 w-auto" />
      </div>
      <span class="text-white font-semibold text-sm leading-tight hidden sm:block">Portal RRHH<br /><span class="text-[var(--color-accent)] text-xs font-normal">LAATS Panamá</span></span>
    </a>
    <nav class="hidden md:flex items-center gap-6">
      <a href="#accesos" class="text-white/80 hover:text-white text-sm font-medium transition-colors">Accesos Rápidos</a>
      <a href="#calculadoras" class="text-white/80 hover:text-white text-sm font-medium transition-colors">Calculadoras</a>
      <a href="#faq" class="text-white/80 hover:text-white text-sm font-medium transition-colors">FAQ</a>
    </nav>
    <!-- Mobile menu button -->
    <button
      x-data="{ open: false }"
      @click="open = !open"
      class="md:hidden text-white p-2"
      aria-label="Menú"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>
<!-- Spacer for fixed header -->
<div class="h-16"></div>
