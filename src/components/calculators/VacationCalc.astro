---
---

<div
  x-data="{
    salario: '',
    meses: 11,
    resultado: null,
    calcular() {
      const s = parseFloat(this.salario) || 0;
      const m = parseFloat(this.meses) || 0;
      if (s <= 0) return;
      const diasCorresponden = parseFloat(((m / 11) * 30).toFixed(2));
      const montoVacaciones = parseFloat(((s / 30) * diasCorresponden).toFixed(2));
      this.resultado = { diasCorresponden, montoVacaciones };
    }
  }"
  class="space-y-6"
>
  <p class="text-xs text-[var(--color-muted)] bg-blue-50 border border-blue-100 rounded-lg px-4 py-2">
    Código de Trabajo de Panamá, Art. 54 — 30 días de vacaciones por cada 11 meses trabajados
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-[var(--color-text)] mb-1">Salario mensual (B/.)</label>
      <input
        x-model="salario"
        type="number"
        min="0"
        placeholder="Ej: 800"
        class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30 focus:border-[var(--color-primary)]"
      />
    </div>
    <div>
      <label class="block text-sm font-medium text-[var(--color-text)] mb-1">
        Meses trabajados: <span class="text-[var(--color-primary)] font-semibold" x-text="meses"></span>
      </label>
      <input
        x-model="meses"
        type="range"
        min="1"
        max="22"
        class="w-full accent-[var(--color-primary)] mt-2"
      />
      <div class="flex justify-between text-xs text-[var(--color-muted)] mt-1">
        <span>1 mes</span><span>22 meses</span>
      </div>
    </div>
  </div>

  <button
    @click="calcular()"
    class="bg-[var(--color-primary)] text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-[var(--color-primary-dark)] transition-colors"
  >
    Calcular vacaciones
  </button>

  <div x-show="resultado" x-transition class="bg-green-50 border border-green-200 rounded-xl p-5 space-y-3" style="display:none;">
    <h4 class="font-semibold text-green-800 mb-3">Resultado</h4>
    <div class="grid grid-cols-2 gap-2 text-sm">
      <span class="text-[var(--color-muted)]">Días que corresponden:</span>
      <span class="font-mono font-semibold text-[var(--color-text)]" x-text="(resultado?.diasCorresponden ?? 0) + ' días'"></span>
    </div>
    <div class="border-t border-green-200 pt-3 flex justify-between items-center">
      <span class="font-semibold text-green-800">Monto estimado:</span>
      <span class="font-mono text-2xl font-bold text-green-700" x-text="'B/. ' + (resultado?.montoVacaciones ?? 0).toFixed(2)"></span>
    </div>
    <p class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 mt-2 leading-relaxed">
      ⚠️ <strong>Referencia orientativa.</strong> El valor real dependerá del salario efectivamente devengado por el empleado, incluyendo sobretiempos y otros ingresos variables del período.
    </p>
  </div>
</div>
