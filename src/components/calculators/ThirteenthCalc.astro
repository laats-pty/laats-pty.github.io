---
---

<div
  x-data="{
    salario: '',
    cuota: 'abril',
    get mesesPeriodo() {
      return this.cuota === 'abril' ? 3 : 4;
    },
    resultado: null,
    calcular() {
      const s = parseFloat(this.salario) || 0;
      if (s <= 0) return;
      const m = this.mesesPeriodo;
      const decimoMensualAcumulado = parseFloat((s / 12).toFixed(2));
      const montoDecimo = parseFloat(((s * m) / 12).toFixed(2));
      this.resultado = { montoDecimo, decimoMensualAcumulado, meses: m };
    }
  }"
  class="space-y-6"
>
  <p class="text-xs text-[var(--color-muted)] bg-blue-50 border border-blue-100 rounded-lg px-4 py-2">
    Art. 43 CT — Cuota Abril (3 meses) · Cuota Agosto (4 meses) · Cuota Diciembre (4 meses)
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-[var(--color-text)] mb-1">Salario mensual (B/.)</label>
      <input
        x-model="salario"
        type="number"
        min="0"
        placeholder="Ej: 800"
        class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30 focus:border-[var(--color-primary)]"
      />
    </div>
    <div>
      <label class="block text-sm font-medium text-[var(--color-text)] mb-1">Cuota a calcular</label>
      <select
        x-model="cuota"
        class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30 focus:border-[var(--color-primary)]"
      >
        <option value="abril">Cuota Abril (enero–marzo, 3 meses)</option>
        <option value="agosto">Cuota Agosto (abril–julio, 4 meses)</option>
        <option value="diciembre">Cuota Diciembre (agosto–noviembre, 4 meses)</option>
      </select>
    </div>
  </div>

  <button
    @click="calcular()"
    class="bg-[var(--color-primary)] text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-[var(--color-primary-dark)] transition-colors"
  >
    Calcular décimo tercer mes
  </button>

  <div x-show="resultado" x-transition class="bg-green-50 border border-green-200 rounded-xl p-5 space-y-3" style="display:none;">
    <h4 class="font-semibold text-green-800 mb-3">Resultado</h4>
    <div class="grid grid-cols-2 gap-2 text-sm">
      <span class="text-[var(--color-muted)]">Meses del período:</span>
      <span class="font-mono font-semibold text-[var(--color-text)]" x-text="resultado?.meses + ' meses'"></span>
      <span class="text-[var(--color-muted)]">Décimo mensual acumulado:</span>
      <span class="font-mono font-semibold text-[var(--color-text)]" x-text="'B/. ' + (resultado?.decimoMensualAcumulado ?? 0).toFixed(2)"></span>
    </div>
    <div class="border-t border-green-200 pt-3 flex justify-between items-center">
      <span class="font-semibold text-green-800">Monto de la cuota:</span>
      <span class="font-mono text-2xl font-bold text-green-700" x-text="'B/. ' + (resultado?.montoDecimo ?? 0).toFixed(2)"></span>
    </div>
  </div>
</div>
