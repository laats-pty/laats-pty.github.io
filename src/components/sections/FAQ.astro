---
import type { FAQItem } from '../../lib/types';

interface Props {
  items: FAQItem[];
}
const { items } = Astro.props;

const safeId = (id: number) => parseInt(String(id), 10) || 0;
---

<div class="py-16 px-4 md:px-8 bg-[var(--color-surface)]">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-semibold text-[var(--color-text)] mb-2 text-center">Preguntas Frecuentes</h2>
    <p class="text-[var(--color-muted)] text-center mb-10">Respuestas a las dudas más comunes sobre tus derechos laborales</p>

    <div x-data="{ open: null }" class="space-y-3">
      {items.map((item) => (
        <div class="border border-[var(--color-border)] rounded-xl overflow-hidden">
          <button
            x-on:click={`open = open === ${safeId(item.id)} ? null : ${safeId(item.id)}`}
            class="w-full flex items-center justify-between px-6 py-4 text-left font-medium text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors"
          >
            <span>{item.question}</span>
            <svg
              x-bind:class={`open === ${safeId(item.id)} ? 'rotate-180' : ''`}
              class="w-5 h-5 text-[var(--color-primary)] flex-shrink-0 ml-4 transition-transform duration-200"
              fill="none" stroke="currentColor" viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            x-show={`open === ${safeId(item.id)}`}
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 -translate-y-2"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-2"
            class="px-6 pb-5"
            style="display: none;"
          >
            <p class="text-[var(--color-muted)] leading-relaxed">{item.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
